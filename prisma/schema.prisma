generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String @map("password_hash")

  name   String?
  avatar String?
  city   String?
  bio    String?
  phone  String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
  items  Item[]

  sentOffers     Offer[] @relation("SentOffers")
  receivedOffers Offer[] @relation("ReceivedOffers")

  ownedDeals Deal[]    @relation("DealItemOwner")
  sentDeals  Deal[]    @relation("DealOfferSender")
  messages   Message[] @relation("DealMessages")

  @@map("users")
}

model Role {
  id   String @id @default(cuid())
  name String @unique

  users User[]

  @@map("roles")
}

model Category {
  id   String @id @default(cuid())
  name String
  slug String @unique

  items              Item[]
  acceptedCategories AcceptedCategory[]

  @@map("categories")
}

enum ItemStatus {
  ACTIVE
  INACTIVE
  MATCHED
  ARCHIVED
}

enum ItemCondition {
  NEW
  LIKE_NEW
  USED
  BAD
}

enum ItemAcceptedMode {
  ALL
  SELECTED
}

model Item {
  id String @id @default(uuid())

  ownerId String @map("owner_id")
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  title       String
  description String

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id])

  condition ItemCondition
  status    ItemStatus    @default(ACTIVE)

  acceptedMode       ItemAcceptedMode   @default(ALL) @map("accepted_mode")
  acceptedCategories AcceptedCategory[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  images     ItemImage[]
  offers     Offer[]
  offerItems OfferItem[]

  @@map("items")
}

model ItemImage {
  id String @id @default(uuid())

  itemId String @map("item_id")
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  imageUrl String @map("image_url")
  order    Int

  @@unique([itemId, order])
  @@map("item_images")
}

model AcceptedCategory {
  id String @id @default(uuid())

  itemId String @map("item_id")
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  categoryId String   @map("category_id")
  category   Category @relation(fields: [categoryId], references: [id])

  @@unique([itemId, categoryId])
  @@map("accepted_categories")
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

model Offer {
  id String @id @default(cuid())

  targetItemId String @map("target_item_id")
  targetItem   Item   @relation(fields: [targetItemId], references: [id], onDelete: Cascade)

  senderUserId String @map("sender_user_id")
  senderUser   User   @relation("SentOffers", fields: [senderUserId], references: [id], onDelete: Cascade)

  receiverUserId String @map("receiver_user_id")
  receiverUser   User   @relation("ReceivedOffers", fields: [receiverUserId], references: [id], onDelete: Cascade)

  message String?

  status OfferStatus @default(PENDING)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  offerItems OfferItem[]
  deal       Deal?

  @@map("offers")
}

model OfferItem {
  id String @id @default(cuid())

  offerId String @map("offer_id")
  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)

  itemId String @map("item_id")
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([offerId, itemId])
  @@map("offer_items")
}

enum DealStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Deal {
  id String @id @default(cuid())

  offerId String @unique @map("offer_id")
  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)

  itemOwnerId String @map("item_owner_id")
  itemOwner   User   @relation("DealItemOwner", fields: [itemOwnerId], references: [id], onDelete: Cascade)

  offerSenderId String @map("offer_sender_id")
  offerSender   User   @relation("DealOfferSender", fields: [offerSenderId], references: [id], onDelete: Cascade)

  status DealStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  messages Message[]

  @@map("deals")
}

model Message {
  id String @id @default(cuid())

  dealId String @map("deal_id")
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  senderId String @map("sender_id")
  sender   User   @relation("DealMessages", fields: [senderId], references: [id], onDelete: Cascade)

  text String

  createdAt DateTime @default(now()) @map("created_at")

  @@map("messages")
}
